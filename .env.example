# Optional: override API base URL.
# Default is /v1, which is proxied to https://api.x.ai/v1 by Vite (dev) and Vercel (prod)
# to avoid browser CORS preflight failures.
# VITE_GROK_API_URL=/v1

# Optional: public base URL for app-facing proxy endpoints used by xAI.
# Set this when the app is deployed or behind a tunnel so xAI can fetch private video uploads.
# VITE_PUBLIC_APP_URL=https://your-domain.example

# API key is entered in the app's Login page and stored in a browser cookie.
# VITE_GROK_API_KEY is intentionally unused.

# Private S3 upload settings for video extension
# Bucket: grk-outputs
# Region: ap-south-1
S3_BUCKET_NAME=grk-outputs
S3_REGION=ap-south-1
S3_OBJECT_PREFIX=grok-video-edits
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional, only if your AWS credentials are temporary
# S3_SESSION_TOKEN=
