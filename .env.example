# Optional: override API base URL.
# Default is /v1, which is proxied to https://api.x.ai/v1 by Vite (dev) and Vercel (prod)
# to avoid browser CORS preflight failures.
# VITE_GROK_API_URL=/v1

# API key is entered in the app's Login page and stored in a browser cookie.
# VITE_GROK_API_KEY is intentionally unused.
